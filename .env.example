CODEAUDIT_REPORT_DIR=data/reports

# Optional LLM config. Leave LLM_API_KEY empty to use rule-template fallback.
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=30

# OPENAI_API_KEY is also supported as a fallback when LLM_API_KEY is empty.
OPENAI_API_KEY=
