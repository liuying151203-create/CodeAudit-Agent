CODEAUDIT_REPORT_DIR=data/reports
CODEAUDIT_REPORT_RETENTION_ENABLED=true
CODEAUDIT_REPORT_MAX_COUNT=100
CODEAUDIT_REPORT_MAX_AGE_DAYS=30
CODEAUDIT_MCP_CONFIG=config/mcp_servers.json

# Optional LLM config. Leave LLM_API_KEY empty to use rule-template fallback.
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=30
LLM_VULNKB_RERANK=false

# OPENAI_API_KEY is also supported as a fallback when LLM_API_KEY is empty.
OPENAI_API_KEY=
